local camera = workspace.CurrentCamera
  -- always use CurrentCamera
function getTargetPart(character)
    if getgenv().selectedTargetPart == "Random" then
        local possibleParts = {"Head", "HumanoidRootPart"}
        local randomPartName = possibleParts[math.random(1, #possibleParts)]
        return character:FindFirstChild(randomPartName)
    else
        return character:FindFirstChild(getgenv().selectedTargetPart)
    end
end

if hookmetamethod then
    local oldIndex
    oldIndex = hookmetamethod(camera, "__index", function(self, key)
        local realValue = oldIndex(self, key)
        if key == "ViewportSize"
            and getgenv().SilentAimToggled
            and getgenv().gechance > math.random(1, 100)
            and debug.traceback():find("GetMouse")
        then
            if getgenv().cachedTargetPlayer and getgenv().cachedTargetPlayer.Character then
                local head = getTargetPart(getgenv().cachedTargetPlayer.Character)
                if head then
                    local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
                    return Vector2.new(screenPos.X * 2, screenPos.Y * 2)
                end
            end
        end
        return realValue
    end)
end
